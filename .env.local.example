# ===== Database =====
# SQLite out-of-the-box (no server needed). For production, switch to a
# Postgres URL like: postgresql://user:pass@host:5432/staynp
DATABASE_URL="file:./dev.db"

# ===== Auth =====
# Use a long, random string in production (e.g. `openssl rand -hex 64`)
JWT_SECRET="change-me-to-a-long-random-secret-in-production"

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Email (SMTP for OTP + booking emails) =====
# Leave SMTP_* blank in development — OTP codes will be printed to the server
# console so you can copy them manually.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="StayNP <no-reply@staynp.local>"

# ===== SMS (Aakash SMS for phone OTP) =====
# Leave blank in development — OTP codes will be printed to the server console.
AAKASH_SMS_TOKEN=

# ===== eSewa =====
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY="8gBm/:&EnhH.1/q"
NEXT_PUBLIC_ESEWA_PAYMENT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form

# ===== Khalti =====
KHALTI_SECRET_KEY=
NEXT_PUBLIC_KHALTI_PUBLIC_KEY=

# ===== Google Maps (optional, client-side) =====
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
